# Mapbox GL JS access token (https://account.mapbox.com/access-tokens/)
VITE_MAPBOX_TOKEN=

# Firebase project config (https://console.firebase.google.com → Project Settings → General)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# Firebase App Check (reCAPTCHA Enterprise)
VITE_RECAPTCHA_SITE_KEY=

# Google Places API (New) — optional, enables venue search near midpoint
VITE_GOOGLE_PLACES_API_KEY=
