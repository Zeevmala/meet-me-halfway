# Mapbox GL JS access token (https://account.mapbox.com/access-tokens/)
VITE_MAPBOX_TOKEN=

# Firebase project config (https://console.firebase.google.com → Project Settings → General)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=

# API base URL (optional — defaults to window.location.origin in dev via Vite proxy)
# VITE_API_BASE_URL=http://localhost:8000
