{
  "expo": {
    "name": "Meet Me Halfway",
    "slug": "meet-me-halfway",
    "version": "1.0.0",
    "scheme": "meetmehalfway",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.meetmehalfway.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.meetmehalfway.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      ["expo-router", { "origin": "https://meetmehalfway.app" }],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Meet Me Halfway needs your location to compute the meeting point.",
          "locationWhenInUsePermission": "Meet Me Halfway needs your location to compute the meeting point."
        }
      ],
      "@rnmapbox/maps"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    }
  }
}
