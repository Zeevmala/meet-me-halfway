{
  "rules": {
    "sessions": {
      "$code": {
        ".read": "auth != null",
        "created": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.isNumber()"
        },
        "creatorUid": {
          ".write": "auth != null && !data.exists()",
          ".validate": "newData.isString() && newData.val() === auth.uid"
        },
        "participantUids": {
          "$uid": {
            ".write": "auth != null && !data.exists() && $uid === auth.uid",
            ".validate": "newData.isBoolean() && newData.val() === true"
          }
        },
        "participants": {
          "$uid": {
            ".write": "auth != null && $uid === auth.uid",
            ".validate": "newData.hasChildren(['lat', 'lng', 'accuracy', 'ts'])",
            "lat": { ".validate": "newData.isNumber() && newData.val() >= -90 && newData.val() <= 90" },
            "lng": { ".validate": "newData.isNumber() && newData.val() >= -180 && newData.val() <= 180" },
            "accuracy": { ".validate": "newData.isNumber() && newData.val() >= 0" },
            "ts": { ".validate": "newData.isNumber()" },
            "$other": { ".validate": false }
          }
        },
        "$other": { ".validate": false }
      }
    }
  }
}
