# PostgreSQL / PostGIS
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/meetmehalfway

# Firebase Admin SDK (JSON string of service account credentials)
FIREBASE_CREDENTIALS_JSON={}

# Google Places API (New)
GOOGLE_PLACES_KEY=your_google_places_api_key

# Mapbox (used by backend for any server-side geo, also injected into PWA via VITE_ prefix)
MAPBOX_TOKEN=pk.your_mapbox_public_token

# WhatsApp Business API
WHATSAPP_TOKEN=your_whatsapp_verify_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_APP_SECRET=your_app_secret

# App domain for share links
APP_DOMAIN=https://meetmehalfway.app

# Session expiry
SESSION_TTL_HOURS=4

# CORS origins (comma-separated; use * for dev)
CORS_ORIGINS=*

# HMAC secret for signing share links (leave empty to disable)
SESSION_LINK_SECRET=

# PWA-specific (Vite injects VITE_* vars into client bundle)
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
