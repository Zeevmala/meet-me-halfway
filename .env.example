# Mapbox (map rendering + Directions API)
VITE_MAPBOX_TOKEN=pk.your_mapbox_public_token

# Firebase Realtime Database (live session sync)
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id

# Firebase App Check (reCAPTCHA Enterprise)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_enterprise_site_key

# Google Places API (New) — optional, enables venue search near midpoint
VITE_GOOGLE_PLACES_API_KEY=your_google_places_api_key
